 unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Be Vietnam Pro';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"fb685fc3-b73b-439a-be62-91f0952a1262\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Be Vietnam Pro';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"abae4f12-c937-41ce-9ed0-a3952564974a\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Be Vietnam Pro';\n  font-style: normal;\n  font-weight: 800;\n  font-display: swap;\n  src: url(\"9a2540f3-cf64-4c08-af9c-1e2bed1974a9\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n@font-face{font-family:'BEBECHIC';src:url(\"afc106b8-c76d-4968-b7a0-266d510da010\") format('truetype');font-weight:900;font-display:swap}\n@font-face{font-family:'Ganh';src:url(\"ed54493c-cf98-4e5e-b687-cd599c639ac6\") format('opentype');font-weight:400;font-style:normal;font-display:swap}\n@font-face{font-family:'Ganh';src:url(\"1d7636f4-b729-47e6-ad9d-e6da432acabd\") format('opentype');font-weight:400;font-style:italic;font-display:swap}\n@font-face{font-family:'Ganh';src:url(\"9efc07b1-df1e-4d07-a193-6c46fcf60ad7\") format('opentype');font-weight:200;font-style:normal;font-display:swap}\n\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n\n:root{\n  --cream:#FFFCF5;\n  --mint-100:#E7FEF7;\n  --mint-200:#B6E2D3;\n  --mint-300:#8FD8C3;\n  --mint-500:#74AF9E;\n  --teal:#176676;\n  --teal-900:#1A3A40;\n  --blush-200:#FFD8DB;\n  --sun:#FFE28A;\n  --ink:#1A3A40;\n  --ink2:#3D5A60;\n  --ink3:#7A8E92;\n  --line:#E8EEE9;\n  --milk:#FFFFFF;\n  --ok:#6BBF8A;\n  --warn:#F0B54A;\n  --err:#E87878;\n  --sh-sm:0 2px 12px rgba(23,102,118,.07),0 1px 3px rgba(23,102,118,.04);\n  --sh-md:0 8px 28px rgba(23,102,118,.10),0 2px 8px rgba(23,102,118,.05);\n}\n\nhtml{background:var(--cream)}\nbody{font-family:'Be Vietnam Pro',system-ui,sans-serif;color:var(--ink);background:var(--cream);-webkit-font-smoothing:antialiased;text-wrap:pretty}\n\n/* ── TOPBAR ── */\n.topbar{position:sticky;top:0;z-index:20;background:rgba(255,252,245,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--line);padding:14px 36px;display:flex;align-items:center;justify-content:space-between}\n.tb-brand{font-family:'BEBECHIC',sans-serif;font-size:16px;letter-spacing:.12em;color:var(--teal);text-transform:uppercase}\n.tb-right{display:flex;align-items:center;gap:12px}\n.tb-meta{font-size:12px;color:var(--ink3)}\n.tb-pill{background:var(--mint-100);border:1px solid var(--mint-200);border-radius:999px;padding:5px 14px;font-size:11.5px;color:var(--teal);font-weight:700;letter-spacing:.4px}\n\n/* ── COVER ── */\n.cover{background:linear-gradient(160deg,var(--mint-300) 0%,var(--mint-200) 100%);padding:72px 48px 64px;position:relative;overflow:hidden;border-bottom:2px solid var(--mint-200)}\n.cover::before{content:'';position:absolute;top:-80px;right:-80px;width:320px;height:320px;border-radius:50%;background:rgba(23,102,118,.1)}\n.cover::after{content:'';position:absolute;bottom:-60px;left:40px;width:200px;height:200px;border-radius:50%;background:rgba(23,102,118,.07)}\n/* dot grid */\n.cover-dots{position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.12) 1px,transparent 1px);background-size:28px 28px;pointer-events:none}\n.cover-inner{max-width:860px;margin:0 auto;position:relative;z-index:1}\n.cover-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.65);border:1px solid rgba(255,255,255,.8);border-radius:999px;padding:6px 16px;font-size:11.5px;color:var(--teal);font-weight:700;letter-spacing:1.2px;text-transform:uppercase;margin-bottom:24px}\n.cover-eyebrow::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--mint-300)}\n.cover h1{font-family:'BEBECHIC',sans-serif;font-size:64px;text-transform:uppercase;letter-spacing:.06em;color:var(--teal);line-height:.95;margin-bottom:18px}\n.cover-sub{font-family:'Ganh',sans-serif;font-size:22px;font-weight:400;color:var(--teal-900);margin-bottom:32px;letter-spacing:.02em;opacity:.82}\n.cover-chips{display:flex;flex-wrap:wrap;gap:10px}\n.cchip{background:rgba(255,255,255,.65);border:1px solid rgba(255,255,255,.85);border-radius:999px;padding:7px 16px;font-size:12.5px;color:var(--ink2);font-weight:500;display:flex;align-items:center;gap:7px}\n.cchip::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--teal);flex-shrink:0}\n\n/* ── WRAP ── */\n.wrap{max-width:900px;margin:0 auto;padding:48px 28px 96px}\n\n/* ── SECTION ── */\nsection{margin-top:60px}\n.sec-head{display:flex;align-items:center;gap:0;margin-bottom:28px;padding-bottom:18px;border-bottom:1.5px solid var(--mint-200)}\n.sec-num{font-family:'Ganh',sans-serif;font-style:italic;font-weight:200;font-size:48px;color:var(--mint-300);line-height:1;flex-shrink:0;padding-right:18px;border-right:2px solid var(--mint-200);margin-right:18px}\n.sec-title h2{font-family:'Ganh',sans-serif;font-weight:400;font-size:28px;color:var(--teal-900);margin:0}\n.sec-sub{font-size:13px;color:var(--ink3);margin-top:5px}\n\n/* ── CARD ── */\n.card{background:var(--milk);border-radius:22px;border:1px solid var(--line);border-top:3px solid var(--mint-200);box-shadow:var(--sh-sm);padding:28px 30px;margin-bottom:16px}\n.card:last-child{margin-bottom:0}\n.card-title{font-family:'Ganh',sans-serif;font-weight:400;font-size:17px;color:var(--teal);margin-bottom:16px;padding-left:14px;border-left:4px solid var(--mint-300)}\n\n/* ── CODE / FORMAT BOX ── */\n.fmt-box{background:#1A3A40;border-radius:14px;padding:18px 22px;margin-bottom:14px;font-family:'Be Vietnam Pro',monospace;font-size:13.5px;color:#C8E8E4;line-height:2;overflow-x:auto}\n.fmt-box .hl{color:#8FD8C3;font-weight:700}\n.fmt-box .sep{color:#74AF9E;opacity:.6}\n.fmt-box .opt{color:#FFE28A;font-style:italic}\n.fmt-box .cmt{color:#74AF9E;font-size:12px;font-style:italic}\n\n/* ── EXAMPLE ROWS ── */\n.ex-grid{display:grid;gap:8px}\n.ex-row{display:grid;grid-template-columns:18px 1fr;gap:10px;align-items:start;padding:10px 14px;border-radius:10px;font-size:13px}\n.ex-row.ok{background:rgba(107,191,138,.07);border:1px solid rgba(107,191,138,.22)}\n.ex-row.no{background:rgba(232,120,120,.06);border:1px solid rgba(232,120,120,.18)}\n.ex-row .ic{font-size:14px;margin-top:1px;flex-shrink:0}\n.ex-row .txt{color:var(--ink2);line-height:1.5}\n.ex-row .txt strong{font-family:'Be Vietnam Pro',monospace;font-size:13px;display:block;margin-bottom:2px}\n.ex-row.ok .txt strong{color:#1f7a4f}\n.ex-row.no .txt strong{color:#A33;text-decoration:line-through}\n.ex-row .txt small{color:var(--ink3);font-size:12px}\n\n/* ── TABLE ── */\n.tbl-wrap{background:var(--milk);border-radius:16px;overflow:hidden;border:1px solid var(--line);box-shadow:var(--sh-sm)}\ntable{width:100%;border-collapse:collapse;font-size:13.5px}\nthead th{background:var(--mint-100);color:var(--teal);text-align:left;font-weight:800;padding:13px 16px;border-bottom:2px solid var(--mint-200);font-size:11.5px;letter-spacing:.5px;text-transform:uppercase}\ntbody td{padding:13px 16px;border-bottom:1px solid var(--line);color:var(--ink2);vertical-align:top;line-height:1.55}\ntbody tr:last-child td{border-bottom:none}\ntbody tr:nth-child(even) td{background:rgba(231,254,247,.15)}\n.td-code{font-family:'Be Vietnam Pro',monospace;font-size:12.5px;color:var(--teal);background:var(--mint-100);padding:2px 8px;border-radius:6px;display:inline-block}\n\n/* ── PILL LABELS ── */\n.pl{display:inline-block;padding:3px 11px;border-radius:999px;font-size:11.5px;font-weight:700;letter-spacing:.04em;white-space:nowrap}\n.pl-teal{background:rgba(143,216,195,.22);color:var(--teal)}\n.pl-ok{background:rgba(107,191,138,.16);color:#1f7a4f}\n.pl-warn{background:rgba(240,181,74,.18);color:#8B5A00}\n.pl-err{background:rgba(232,120,120,.15);color:#A33}\n\n/* ── FOLDER TREE ── */\n.tree{background:#1A3A40;border-radius:16px;padding:22px 26px;font-family:'Be Vietnam Pro',monospace;font-size:13px;line-height:2;color:#C8E8E4}\n.tree .folder{color:#8FD8C3;font-weight:700}\n.tree .file{color:#FFFCF5;opacity:.8}\n.tree .note{color:#74AF9E;font-style:italic;font-size:12px}\n.tree .indent1{padding-left:22px}\n.tree .indent2{padding-left:44px}\n.tree .indent3{padding-left:66px}\n\n/* ── DO/DON'T GRID ── */\n.dd-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}\n.dd-col{border-radius:16px;padding:22px}\n.dd-col.do{background:rgba(107,191,138,.07);border:1.5px solid rgba(107,191,138,.25)}\n.dd-col.dont{background:rgba(232,120,120,.06);border:1.5px solid rgba(232,120,120,.2)}\n.dd-col h4{font-size:12.5px;letter-spacing:1.5px;text-transform:uppercase;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:8px}\n.dd-col.do h4{color:#1f7a4f}\n.dd-col.dont h4{color:#A33}\n.dd-col ul{padding-left:16px}\n.dd-col li{font-size:13.5px;color:var(--ink2);margin-bottom:8px;line-height:1.5}\n\n/* ── NOTE BOX ── */\n.note-box{display:flex;gap:14px;align-items:flex-start;background:var(--milk);border-radius:14px;border:1px solid var(--line);border-left:4px solid var(--mint-300);padding:16px 20px;box-shadow:var(--sh-sm);margin:16px 0}\n.note-box.warn{border-left-color:var(--warn)}\n.note-box.err{border-left-color:var(--err)}\n.note-ico{font-size:18px;flex-shrink:0;margin-top:2px}\n.note-box p{font-size:14px;color:var(--ink2);margin:0;line-height:1.65}\n\n/* ── SQUIGGLE DIVIDER ── */\n.squig{display:block;margin:36px auto;opacity:.3}\n\n/* ── FOOTER ── */\nfooter{background:linear-gradient(135deg,var(--mint-300),var(--mint-200));padding:28px 36px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;border-top:2px solid var(--mint-200)}\n.ft-brand{font-family:'BEBECHIC',sans-serif;font-size:20px;letter-spacing:.1em;color:var(--teal);text-transform:uppercase}\n.ft-meta{font-size:12.5px;color:var(--ink2);margin-top:4px;opacity:.75}\n.ft-chips{display:flex;gap:8px;flex-wrap:wrap}\n.ft-chip{background:rgba(255,255,255,.6);border:1px solid rgba(255,255,255,.85);padding:5px 14px;border-radius:999px;font-size:12px;color:var(--teal);font-weight:600}\n\n@media(max-width:720px){\n  .cover h1{font-size:44px}\n  .dd-grid{grid-template-columns:1fr}\n  .wrap{padding:36px 16px 72px}\n  .topbar{padding:12px 20px}\n  .cover{padding:52px 24px 48px}\n}\n@media print{.topbar{display:none}section{break-inside:avoid}}\n<\u002Fstyle>\n<\u002Fhead>\n<body style=\"\">\n\n<!-- TOPBAR -->\n<div class=\"topbar\">\n  <span class=\"tb-brand\" style=\"font-family: BEBECHIC; font-size: 20px; color: rgb(143, 216, 195);\">BEBECHIC<\u002Fspan>\n  <div class=\"tb-right\">\n    <span class=\"tb-meta\">Tháng 6/2026<\u002Fspan>\n    <span class=\"tb-pill\" style=\"\">Design Guidelines<\u002Fspan>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- COVER -->\n<div class=\"cover\">\n  <div class=\"cover-dots\"><\u002Fdiv>\n  <div class=\"cover-inner\">\n    <div class=\"cover-eyebrow\">Tài liệu nội bộ · Design Team<\u002Fdiv>\n    <h1>BEBECHIC<\u002Fh1>\n    <div class=\"cover-sub\">Quy Tắc Đặt Tên &amp; Lưu Trữ File · Dành cho Designer<\u002Fdiv>\n    <div class=\"cover-chips\">\n      <span class=\"cchip\">Áp dụng cho toàn bộ Design Team<\u002Fspan>\n      <span class=\"cchip\">File thiết kế · Ảnh sản phẩm · Export<\u002Fspan>\n      <span class=\"cchip\" style=\"\">Cập nhật Tháng 6/2026<\u002Fspan>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<div class=\"wrap\">\n\n<!-- ══════════════════════════\n     I. NGUYÊN TẮC CHUNG\n══════════════════════════ -->\n<section>\n  <div class=\"sec-head\">\n    <span class=\"sec-num\">I<\u002Fspan>\n    <div class=\"sec-title\">\n      <h2>Nguyên tắc chung<\u002Fh2>\n      <p class=\"sec-sub\">Luôn áp dụng cho mọi loại file trong hệ thống BEBECHIC.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <div class=\"dd-grid\">\n    <div class=\"dd-col do\">\n      <h4><span>✓<\u002Fspan> Nên làm<\u002Fh4>\n      <ul>\n        <li>Dùng tiếng Anh hoặc viết tắt chuẩn, không dấu tiếng Việt<\u002Fli>\n        <li>Dùng dấu gạch ngang <code>-<\u002Fcode> thay khoảng trắng<\u002Fli>\n        <li>Luôn có ngày tháng theo định dạng <strong>DD-MM-YY<\u002Fstrong><\u002Fli>\n        <li>Ghi rõ phiên bản: <code>v1<\u002Fcode>, <code>v2<\u002Fcode>, <code>v1.1<\u002Fcode><\u002Fli>\n        <li>Tên file phản ánh đúng nội dung bên trong<\u002Fli>\n        <li>Dùng chữ thường toàn bộ (lowercase)<\u002Fli>\n        <li>Ghi <code>-final<\u002Fcode> chỉ khi đã được approve chính thức<\u002Fli>\n      <\u002Ful>\n    <\u002Fdiv>\n    <div class=\"dd-col dont\">\n      <h4><span>✕<\u002Fspan> Không làm<\u002Fh4>\n      <ul>\n        <li>Không đặt tên chứa dấu tiếng Việt: á ê ổ ờ…<\u002Fli>\n        <li>Không dùng khoảng trắng, dấu chấm, ký tự đặc biệt: <code>@ # $ % &amp;<\u002Fcode><\u002Fli>\n        <li>Không đặt tên chung chung: <code>final<\u002Fcode>, <code>new<\u002Fcode>, <code>done<\u002Fcode>, <code>ok<\u002Fcode><\u002Fli>\n        <li>Không giữ tên mặc định: <code>Untitled-1.psd<\u002Fcode><\u002Fli>\n        <li>Không đặt : final1, final2,-v99, -last<\u002Fli>\n        <li>Không lưu thẳng vào thư mục gốc không có tổ chức<\u002Fli>\n        <li>Không overwrite file đã được approve — tạo version mới<\u002Fli>\n      <\u002Ful>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ══════════════════════════\n     II. CẤU TRÚC TÊN FILE\n══════════════════════════ -->\n<section>\n  <div class=\"sec-head\">\n    <span class=\"sec-num\">II<\u002Fspan>\n    <div class=\"sec-title\">\n      <h2 style=\"\">Cấu trúc tên file chuẩn<\u002Fh2>\n      <p class=\"sec-sub\">Công thức bắt buộc theo từng loại file.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <!-- 2.1 File thiết kế -->\n  <div class=\"card\">\n    <div class=\"card-title\" style=\"\">2.1 File thiết kế (PTS, AI, ...)<\u002Fdiv>\n    <div class=\"fmt-box\" style=\"background-color: rgb(143, 216, 195);\">\n      <span class=\"hl\" style=\"color: rgb(255, 252, 245)\">[project]<\u002Fspan><span class=\"sep\" style=\"color: rgb(255, 252, 245)\">-<\u002Fspan><span class=\"hl\" style=\"color: rgb(255, 252, 245)\">[type]<\u002Fspan><span class=\"sep\" style=\"color: rgb(255, 252, 245)\">-<\u002Fspan><span class=\"hl\" style=\"color: rgb(255, 252, 245)\">[description]<\u002Fspan><span class=\"sep\" style=\"color: rgb(255, 252, 245)\">-<\u002Fspan><span class=\"hl\" style=\"color: rgb(255, 252, 245)\">[DDMMYY]<\u002Fspan><span class=\"sep\" style=\"color: rgb(255, 252, 245)\">-<\u002Fspan><span class=\"hl\" style=\"color: rgb(255, 252, 245)\">[version]<\u002Fspan><span class=\"sep\">.<\u002Fspan><span class=\"hl\">[ext]<\u002Fspan>\n      <br><span class=\"cmt\" style=\"\"><span style=\"color: rgb(255, 255, 255);\">——— ví dụ ———<\u002Fspan><\u002Fspan>\n      <br><span class=\"opt\" style=\"color: rgb(255, 240, 196)\">bbc-banner-sale1111-081026-v1.fig<\u002Fspan>\n      <br><span class=\"opt\" style=\"color: rgb(255, 240, 196)\">bbc-packaging-bb045-081026-v2.ai<\u002Fspan>\n      <br><span class=\"opt\" style=\"color: rgb(255, 240, 196)\">bbc-thumbnail-backtoschool-081026-v1.1.fig<\u002Fspan>\n    <\u002Fdiv>\n    <div class=\"ex-grid\">\n      <div class=\"ex-row ok\"><span class=\"ic\">✓<\u002Fspan><div class=\"txt\"><strong>bbc-thumbnailshopee-backtoschool-081026-v1.psd<\u002Fstrong><small>Đúng — đủ context, có date, có version<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n      <div class=\"ex-row no\"><span class=\"ic\">✕<\u002Fspan><div class=\"txt\"><strong>banner mới nhất final ok v2.psd<\u002Fstrong><small>Sai — có khoảng trắng, không rõ nội dung, không có date<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n      <div class=\"ex-row no\"><span class=\"ic\">✕<\u002Fspan><div class=\"txt\"><strong>Untitled-3 copy final(1).fig<\u002Fstrong><small>Sai — tên mặc định + copy không kiểm soát được<\u002Fsmall><\u002Fdiv><\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <!-- 2.2 Export/Output -->\n  <div class=\"card\">\n    <div class=\"card-title\">2.2 File export dùng cho sản xuất (JPG, PNG, MP4…)<\u002Fdiv>\n    <div class=\"fmt-box\" style=\"background-color: rgb(26, 58, 64)\">\n      <span class=\"hl\">[project]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[channel]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[description]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[size]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[DDMMYY]<\u002Fspan><span class=\"sep\">.<\u002Fspan><span class=\"hl\">[ext]<\u002Fspan>\n      <br><span class=\"cmt\">——— channel: shopee | tiktok | fb | ig | web | zalo ———<\u002Fspan>\n      <br><span class=\"opt\">bbc-shopee-thumbnail-flashsale-1200x1200-081026.jpg<\u002Fspan>\n      <br><span class=\"opt\">bbc-fb-cover-sale1111-820x312-081026.jpg<\u002Fspan>\n      <br><span class=\"opt\">bbc-tiktok-overlay-intro-1080x1920-081026.mp4<\u002Fspan>\n    <\u002Fdiv>\n    <div class=\"note-box\">\n      <span class=\"note-ico\">💡<\u002Fspan>\n      <p style=\"\">File export <strong>không cần đánh version<\u002Fstrong> vì mỗi lần export mới sẽ có date khác nhau. Chỉ giữ bản export mới nhất trong thư mục <code>/exports/approved/<\u002Fcode>.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <!-- 2.3 Ảnh sản phẩm -->\n  <div class=\"card\">\n    <div class=\"card-title\">2.3 Ảnh sản phẩm gốc (RAW/JPG từ chụp hình)<\u002Fdiv>\n    <div class=\"fmt-box\">\n      <span class=\"hl\">[sku]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[msku]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[angle]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[DDMMYY]<\u002Fspan><span class=\"sep\">.<\u002Fspan><span class=\"hl\">[ext]<\u002Fspan>\n      <br><span class=\"cmt\">——— angle: front | back | side | detail | flat | model ———<\u002Fspan>\n      <br><span class=\"opt\">BBC2024-BT10-BT10A-front-081026.jpg<\u002Fspan>\n      <br><span class=\"opt\">BBC2024-BT19-BT19A-model-081026.jpg<\u002Fspan>\n      <br><span class=\"opt\">BBC2024-BB043-BB043A-detail-081026.jpg<\u002Fspan>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <!-- 2.4 Video -->\n  <div class=\"card\">\n    <div class=\"card-title\">2.4 File video &amp; motion<\u002Fdiv>\n    <div class=\"fmt-box\">\n      <span class=\"hl\">[project]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[type]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[description]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[resolution]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[DDMMYY]<\u002Fspan><span class=\"sep\">-<\u002Fspan><span class=\"hl\">[version]<\u002Fspan><span class=\"sep\">.<\u002Fspan><span class=\"hl\">[ext]<\u002Fspan>\n      <br><span class=\"cmt\">——— type: reel | story | tiktok | livestream-overlay | ads ———<\u002Fspan>\n      <br><span class=\"opt\">bbc-motion-saleshop-010726-v1.mp4<\u002Fspan>\n      <br><span class=\"opt\">bbc-story-kolhoaithuong-010726-v2.mp4<\u002Fspan>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ══════════════════════════\n     III. CẤU TRÚC THƯ MỤC\n══════════════════════════ -->\n<section>\n  <div class=\"sec-head\">\n    <span class=\"sec-num\">III<\u002Fspan>\n    <div class=\"sec-title\">\n      <h2>Cấu trúc thư mục chuẩn<\u002Fh2>\n      <p class=\"sec-sub\">Tổ chức trên Google Drive / hệ thống lưu trữ nội bộ BEBECHIC.<\u002Fp>\n    <\u002Fdiv>\n  <\u002Fdiv>\n\n  <div class=\"card\">\n    <div class=\"card-title\">3.1 Cấu trúc thư mục tổng thể<\u002Fdiv>\n    <div class=\"tree\">\n      <div><span class=\"folder\">📁 BEBECHIC — Design<\u002Fspan><\u002Fdiv>\n      <div class=\"indent1\"><span class=\"folder\">📁 01_Brand-Assets<\u002Fspan> <span class=\"note\">← logo, font, color, mascot — KHÔNG sửa<\u002Fspan><\u002Fdiv>\n      <div class=\"indent2\"><span class=\"folder\">📁 Logo<\u002Fspan><\u002Fdiv>\n      <div class=\"indent2\"><span class=\"folder\">📁 Fonts<\u002Fspan><\u002Fdiv>\n      <div class=\"indent2\"><span class=\"folder\">📁 Mascot<\u002Fspan><\u002Fdiv>\n      <div class=\"indent2\"><span class=\"folder\">📁 Color-Palette<\u002Fspan><\u002Fdiv>\n      <div class=\"indent1\"><span class=\"folder\">📁 02_Campaigns<\u002Fspan><\u002Fdiv>\n      <div class=\"indent2\"><span class=\"folder\">📁 2026_Q3_SummerSale<\u002Fspan> <span class=\"note\">← đặt tên: YYYY_Qn_CampaignName<\u002Fspan><\u002Fdiv>\n      <div class=\"indent3\"><span class=\"folder\">📁 _source<\u002Fspan> <span class=\"note\">← file gốc .fig .ai .psd<\u002Fspan><\u002Fdiv>\n      <div class=\"indent3\"><span class=\"folder\">📁 exports<\u002Fspan><\u002Fdiv>\n      <div class=\"indent3\"><span class=\"folder\">📁 approved<\u002Fspan> <span class=\"note\">← đã duyệt, ready to use<\u002Fspan><\u002Fdiv>\n      <div class=\"indent3\"><span class=\"folder\">📁 assets<\u002Fspan> <span class=\"note\">← ảnh, icon đính kèm<\u002Fspan><\u002Fdiv>\n      <div class=\"indent1\"><span class=\"folder\">📁 03_Products<\u002Fspan><\u002Fdiv>\n      <div class=\"indent2\"><span class=\"folder\">📁 2026_Q3<\u002Fspan><\u002Fdiv>\n      <div class=\"indent3\"><span class=\"folder\">📁 BBC2024-VY01<\u002Fspan> <span class=\"note\">← theo SKU<\u002Fspan><\u002Fdiv>\n      <div class=\"indent1\"><span class=\"folder\">📁 04_Channel-Templates<\u002Fspan><\